# Kamal secret references. Each entry is a shell expression Kamal evaluates
# at deploy time and exports as an env var. The values themselves never leave
# this machine — only the result of these expressions is sent to the server.
#
# Before first deploy, create the files referenced below. Suggested layout
# (gitignored — see .gitignore):
#
#   config/credentials/deployment/
#     kamal_password.key      Docker Hub password for `dtenner` registry user
#     postgres_pw_prod.key    `openssl rand -hex 24`
#     auth_token_prod.key     `openssl rand -hex 32` — bearer token Lume uses
#     voyage_api.key          Voyage AI key (also in lume repo's automation/config)
#
# config/master.key already exists; RAILS_MASTER_KEY reads from it directly.

RAILS_MASTER_KEY=$(cat config/master.key)
KAMAL_REGISTRY_PASSWORD=$(cat config/credentials/deployment/kamal_password.key)
POSTGRES_PASSWORD=$(cat config/credentials/deployment/postgres_pw_prod.key)
AUTH_TOKEN=$(cat config/credentials/deployment/auth_token_prod.key)
VOYAGE_API_KEY=$(cat config/credentials/deployment/voyage_api.key)
DATABASE_URL="postgres://mnemos:$(cat config/credentials/deployment/postgres_pw_prod.key)@mnemos-postgres:5432/mnemos_production"

# Mnemos deployment configuration. Copy to .env and fill in.
# Never commit .env — it's in .gitignore.

# === Required ===

# A long random secret. The agent presents this as `Authorization: Bearer <token>`
# on every API call. Generate with:  openssl rand -hex 32
AUTH_TOKEN=

# Rails master key (the contents of config/master.key). Required to decrypt
# Rails credentials in production. Generate with:  bin/rails credentials:edit
RAILS_MASTER_KEY=

# Postgres password. Generate with:  openssl rand -hex 24
POSTGRES_PASSWORD=

# === Embedding provider — pick exactly one ===

# Default: openai. Other valid values: gemini, voyage, local
EMBEDDING_PROVIDER=openai

# All embeddings stored in this DB must come from a model producing this many
# dimensions. Voyage-3 is 1024 native; OpenAI text-embedding-3-large supports
# 1024 via the dimensions param; Gemini gemini-embedding-001 supports 1024 via
# outputDimensionality. Changing this requires a re-embed of every node.
EMBEDDING_DIMENSION=1024

# OpenAI (default provider)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Google Gemini
# GEMINI_API_KEY=
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Voyage AI
# VOYAGE_API_KEY=
# VOYAGE_EMBEDDING_MODEL=voyage-3

# Local sidecar (see sidecar/embedder/ for a reference impl)
# EMBEDDING_SIDECAR_URL=http://embedder:8080

# === Optional: decay parameters ===
#
# Daily mechanical sweep applied to the graph at 03:00 service-local time.
# These are the only parameters that change service behaviour without an
# explicit API call from the agent.

DECAY_RATE=0.005
CHARGE_DECAY_RATE=0.001
CHARGE_DECAY_FLOOR=0.1

# === Optional: deployment ===

# Host port to expose the app on. Defaults to 3000.
# MNEMOS_PORT=3000
